# Backend — staging template (Render / staging host)
# Populate via host secrets manager — do not commit real values.

NODE_ENV=staging
PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/travelplan-staging
REDIS_URL=redis://:PASSWORD@REDIS_HOST:6379
JWT_SECRET=
FRONTEND_URL=https://staging.your-frontend.vercel.app
FRONTEND_URLS=
LOG_LEVEL=info
ADMIN_EMAILS=
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PREFIX=travel-documents-staging
GEMINI_API_KEY=
OPENWEATHER_API_KEY=
GOOGLE_GEOCODING_API_KEY=
SERPAPI_KEY=
