# Backend — development template
# Copy to backend/.env.development or merge into backend/.env

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/travelplan
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=dev-only-change-me
