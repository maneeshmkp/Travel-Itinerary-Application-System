# Backend — production template (Render)
# Set these as Render environment variables / GitHub Secrets. Never commit real values.

NODE_ENV=production
PORT=5000
TRUST_PROXY=true
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/travelplan
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
JWT_SECRET=
FRONTEND_URL=https://travel-itinerary-application-system.vercel.app
FRONTEND_URLS=
LOG_LEVEL=info
ADMIN_EMAILS=
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PREFIX=travel-documents
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENWEATHER_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_MAPS_API_KEY=
SERPAPI_KEY=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
