# Frontend environment (Vite)
# Copy to frontend/.env for local development.
# For production (Vercel), set the same keys in the Vercel dashboard
# OR rely on frontend/.env.production (committed defaults).

# API base — MUST include /api
# Local (optional if using Vite proxy): leave unset → /api
# Production:
VITE_API_URL=https://travel-itinerary-application-system.onrender.com/api

# Socket.IO origin (no /api)
VITE_SOCKET_URL=https://travel-itinerary-application-system.onrender.com

# Optional — trip map tries Google first, then OpenStreetMap automatically on failure.
# Create a key at https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API
# Restrict HTTP referrers to http://localhost:3000/* and your Vercel domain
VITE_GOOGLE_MAPS_API_KEY=

# Force OpenStreetMap only (skip Google): leaflet | auto (default)
# VITE_MAP_PROVIDER=leaflet
