# Optional — trip map tries Google first, then OpenStreetMap automatically on failure.
# Create a key at https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API
# Restrict HTTP referrers to http://localhost:3000/* (and your production domain)
# Billing must be enabled on the Google Cloud project (free tier applies).
VITE_GOOGLE_MAPS_API_KEY=

# Force OpenStreetMap only (skip Google): leaflet | auto (default)
# VITE_MAP_PROVIDER=leaflet
