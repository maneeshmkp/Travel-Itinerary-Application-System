# Shared secrets for docker compose (copy → .env.docker — never commit .env.docker)
# cp .env.docker.example .env.docker

NODE_ENV=development
JWT_SECRET=change-me-local-docker-secret-min-32-chars
FRONTEND_URL=http://localhost:3000
MONGO_DB_NAME=travelplan
MONGO_HOST_PORT=27017
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=5000
FRONTEND_HOST_PORT=3000

# Frontend build args (baked into nginx image)
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAP_PROVIDER=auto

# Optional integrations (leave blank for local demo modes)
ADMIN_EMAILS=
OPENWEATHER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEOCODING_API_KEY=
SERPAPI_KEY=
STORAGE_PROVIDER=local
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PREFIX=travel-documents
LOG_LEVEL=info
