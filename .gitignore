# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
**/node_modules/

# Build outputs
frontend/build/
frontend/dist/
backend/dist/
backend/build/
dist/
build/
coverage/

# Environment / secrets — never commit real credentials
.env
.env.local
.env.*.local
.env.docker
frontend/.env
backend/.env
*.pem
*.p12
*.key
credentials.json
service-account*.json
# Keep committed templates (*.example / *.example.env)
!.env.example
!**/.env.example
!.env.*.example
!**/*.example.env

# Logs
*.log
backend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Cache / temporary
.cache/
.turbo/
tmp/
temp/

# Uploaded documents (local storage)
backend/uploads/

# Playwright / test artifacts
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Lighthouse raw JSON (regenerate; summary lives in PERFORMANCE.md)
docs/lighthouse-report.json

# OpenAPI generator scratch
backend/docs/openapi/.cache/

# Vite / tooling caches
frontend/node_modules/.vite/
**/.vite/
