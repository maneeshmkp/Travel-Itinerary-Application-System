# MongoDB
MONGODB_URI=

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=
JWT_EXPIRE=30d

# Admin access for /api/monitoring and System Monitoring UI
# Comma-separated emails treated as admin (in addition to User.role=admin)
# ADMIN_EMAILS=you@example.com

# Optional Redis — caching, rate limits, Socket.IO adapter, BullMQ
# Docker Compose: redis://redis:6379
# Local: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Logging
# LOG_LEVEL=info

# OpenWeather (server-side only)
OPENWEATHER_API_KEY=

# Unsplash (server-side only — never expose in frontend)
UNSPLASH_ACCESS_KEY=
UNSPLASH_APPLICATION_NAME=Travel Itinerary System

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Live flights & hotels — free signup at https://serpapi.com (100 searches/month)
SERPAPI_KEY=

# Default flight origin IATA code (e.g. DEL, BOM)
# AVAILABILITY_ORIGIN_AIRPORT=DEL
# AVAILABILITY_ORIGIN_CITY=Delhi

# Live IRCTC train search + fares (free signup at https://railkit.rajivdubey.dev)
RAILKIT_API_KEY=
# Legacy alias also supported:
# IRCTC_API_KEY=

# Live redBus bus fares — SeatSeller partner API (contact partners@redbus.in)
SEATSELLER_CONSUMER_KEY=
SEATSELLER_CONSUMER_SECRET=
# SEATSELLER_ACCESS_TOKEN=
# SEATSELLER_ACCESS_TOKEN_SECRET=
# SEATSELLER_API_BASE=https://api.seatseller.travel

# Geocoding (optional)
NOMINATIM_USER_AGENT=TravelItinerarySystem/1.0

# Notifications — cron every 15 min (set false to disable)
# NOTIFICATION_SCHEDULER=false
# ALLOW_NOTIFICATION_SEED=true
# ALLOW_SCHEDULER_RUN=true

# Calendar OAuth (Google)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/calendar/google/callback

# Calendar OAuth (Microsoft Outlook)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=http://localhost:5000/api/calendar/outlook/callback

# Encrypt calendar tokens (falls back to JWT_SECRET)
# CALENDAR_TOKEN_SECRET=
# BACKEND_URL=http://localhost:5000

# Document Vault storage (local | cloudinary | s3 | azure)
# STORAGE_PROVIDER=local
# DOCUMENT_UPLOAD_DIR=./uploads/documents
# DOCUMENT_SIGNING_SECRET=
# BACKEND_URL=http://localhost:5000

# AWS S3 — recommended for production
# STORAGE_PROVIDER=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_PREFIX=travel-documents

# Azure Blob
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=travel-documents
