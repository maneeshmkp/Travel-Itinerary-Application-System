{
  "name": "travel-itinerary-system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "lint": "npm run lint --prefix backend && npm run lint --prefix frontend",
    "test": "npm run test --prefix backend && npm run test --prefix frontend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:critical": "playwright test --project=critical",
    "test:e2e:report": "playwright show-report",
    "build": "npm run build --prefix frontend",
    "format:check": "prettier --check \"docker-compose.yml\" \"render.yaml\" \"vercel.json\" \".prettierrc.json\" \".github/workflows/**/*.yml\"",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.0",
    "prettier": "^3.6.2"
  }
}
